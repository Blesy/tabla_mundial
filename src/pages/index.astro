---
import Layout from '../layouts/Layout.astro';
import TablaGrupo from '../components/TablaGrupo.astro';
import BracketEliminatorias from '../components/BracketEliminatorias.astro';
import TablaQuiniela from '../components/TablaQuiniela.astro';
import PartidosDelDia from '../components/PartidosDelDia.astro';
import mundialData from '../data/mundial.json';

const { participantes, grupos, eliminatorias } = mundialData;

// Construir lookup de equipos (id -> info)
const equiposInfo: Record<string, { nombre: string; bandera: string }> = {};
for (const grupoKey of Object.keys(grupos)) {
  const grupo = grupos[grupoKey as keyof typeof grupos];
  for (const eq of grupo.equipos) {
    equiposInfo[eq.id] = { nombre: eq.nombre, bandera: eq.bandera };
  }
}

// Determinar campeón
const campeon: string | null = (() => {
  const f = eliminatorias.final;
  if (f.golesLocal === null || f.golesVisitante === null) return null;
  if (f.golesLocal > f.golesVisitante) return f.local;
  if (f.golesLocal < f.golesVisitante) return f.visitante;
  if (f.penalesLocal !== null && f.penalesVisitante !== null) {
    return f.penalesLocal > f.penalesVisitante ? f.local : f.visitante;
  }
  return null;
})();

// Determinar perdedor de un partido de eliminatorias
function getLoser(p: { local: string | null; visitante: string | null; golesLocal: number | null; golesVisitante: number | null; penalesLocal: number | null; penalesVisitante: number | null }): string | null {
  if (!p.local || !p.visitante || p.golesLocal === null || p.golesVisitante === null) return null;
  if (p.golesLocal > p.golesVisitante) return p.visitante;
  if (p.golesLocal < p.golesVisitante) return p.local;
  if (p.penalesLocal !== null && p.penalesVisitante !== null) {
    return p.penalesLocal > p.penalesVisitante ? p.visitante : p.local;
  }
  return null;
}

// Equipos que aparecen en eliminatorias (clasificaron de grupos)
const enEliminatorias = new Set<string>();
for (const p of eliminatorias.treintaDos) {
  if (p.local) enEliminatorias.add(p.local);
  if (p.visitante) enEliminatorias.add(p.visitante);
}

// Detectar eliminados en fase de grupos cuando todos los partidos del grupo están jugados
const grupoLetras = Object.keys(grupos) as Array<keyof typeof grupos>;
const gruposEliminados = new Set<string>();

for (const letra of grupoLetras) {
  const grupo = grupos[letra];
  const stats: Record<string, { pts: number; gf: number; gc: number }> = {};
  for (const eq of grupo.equipos) stats[eq.id] = { pts: 0, gf: 0, gc: 0 };

  let todosJugados = true;
  for (const p of grupo.partidos) {
    if (p.golesLocal === null || p.golesVisitante === null) { todosJugados = false; continue; }
    stats[p.local].gf += p.golesLocal; stats[p.local].gc += p.golesVisitante;
    stats[p.visitante].gf += p.golesVisitante; stats[p.visitante].gc += p.golesLocal;
    if (p.golesLocal > p.golesVisitante) stats[p.local].pts += 3;
    else if (p.golesLocal < p.golesVisitante) stats[p.visitante].pts += 3;
    else { stats[p.local].pts++; stats[p.visitante].pts++; }
  }

  if (todosJugados) {
    const sorted = grupo.equipos.slice().sort((a, b) => {
      const sa = stats[a.id], sb = stats[b.id];
      if (sb.pts !== sa.pts) return sb.pts - sa.pts;
      const gdA = sa.gf - sa.gc, gdB = sb.gf - sb.gc;
      if (gdB !== gdA) return gdB - gdA;
      return sb.gf - sa.gf;
    });
    for (let i = 2; i < sorted.length; i++) {
      if (!enEliminatorias.has(sorted[i].id)) {
        gruposEliminados.add(sorted[i].id);
      }
    }
  }
}

// Consolidar todos los eliminados
const eliminados = new Set<string>(gruposEliminados);
for (const ronda of [eliminatorias.treintaDos, eliminatorias.dieciseis, eliminatorias.cuartos, eliminatorias.semis]) {
  for (const p of ronda) {
    const loser = getLoser(p);
    if (loser) eliminados.add(loser);
  }
}
const loser3 = getLoser(eliminatorias.tercerLugar);
if (loser3) eliminados.add(loser3);
const loserFinal = getLoser(eliminatorias.final);
if (loserFinal) eliminados.add(loserFinal);

const gruposEntries = Object.entries(grupos) as Array<[string, typeof grupos[keyof typeof grupos]]>;

// ─── Partidos del día ───────────────────────────────────────────────────────
type PartidoConContexto = {
  local: string | null;
  visitante: string | null;
  golesLocal: number | null;
  golesVisitante: number | null;
  contexto: string;
  hora: string;
};

const _hoyD = new Date(Date.now() - 7 * 60 * 60 * 1000);
const hoy = `${_hoyD.getUTCFullYear()}-${String(_hoyD.getUTCMonth() + 1).padStart(2, '0')}-${String(_hoyD.getUTCDate()).padStart(2, '0')}`;

const todosConFecha: Array<PartidoConContexto & { fecha: string }> = [];

// Recopilar partidos de grupos con fecha asignada
for (const [letra, grupo] of Object.entries(grupos)) {
  for (const p of grupo.partidos as Array<(typeof grupo.partidos)[0] & { fecha: string | null }>) {
    if (p.fecha) {
      todosConFecha.push({
        local: p.local,
        visitante: p.visitante,
        golesLocal: p.golesLocal,
        golesVisitante: p.golesVisitante,
        contexto: `Grupo ${letra}`,
        fecha: p.fecha,
        hora: (p as any).hora ?? 'TBD',
      });
    }
  }
}

// Recopilar partidos de eliminatorias con fecha asignada
const rondasElim = [
  { partidos: eliminatorias.treintaDos, nombre: 'Dieciseisavos' },
  { partidos: eliminatorias.dieciseis, nombre: 'Octavos de Final' },
  { partidos: eliminatorias.cuartos, nombre: 'Cuartos de Final' },
  { partidos: eliminatorias.semis, nombre: 'Semifinales' },
  { partidos: [eliminatorias.tercerLugar], nombre: '3er y 4to Lugar' },
  { partidos: [eliminatorias.final], nombre: 'Final' },
] as const;

for (const { partidos, nombre } of rondasElim) {
  for (const p of partidos as Array<(typeof partidos)[0] & { fecha: string | null }>) {
    if (p.fecha) {
      todosConFecha.push({
        local: p.local,
        visitante: p.visitante,
        golesLocal: p.golesLocal,
        golesVisitante: p.golesVisitante,
        contexto: nombre,
        fecha: p.fecha,
        hora: (p as any).hora ?? 'TBD',
      });
    }
  }
}

// Construir lookup dueño de equipo
const dueñoEquipo: Record<string, string> = {};
for (const p of participantes) {
  for (const eq of p.equipos) {
    dueñoEquipo[eq] = p.nombre;
  }
}

// Agrupar todos los partidos por fecha (pasados + hoy + futuros)
const fechasConPartidos = [...new Set(
  todosConFecha.map((p) => p.fecha)
)].sort();

const inicioIndex = Math.max(0, (() => {
  const idx = fechasConPartidos.findIndex((f) => f >= hoy);
  return idx === -1 ? fechasConPartidos.length - 1 : idx;
})());

type FechaSlot = {
  fecha: string;
  partidos: PartidoConContexto[];
  esHoy: boolean;
};

const todasFechas: FechaSlot[] = fechasConPartidos.map((f) => ({
  fecha: f,
  partidos: todosConFecha
    .filter((p) => p.fecha === f)
    .sort((a, b) => {
      if (a.hora === 'TBD' && b.hora === 'TBD') return 0;
      if (a.hora === 'TBD') return 1;
      if (b.hora === 'TBD') return -1;
      const toMinutes = (h: string) => {
        const [hh, mm] = h.split(':').map(Number);
        return hh * 60 + mm;
      };
      return toMinutes(a.hora) - toMinutes(b.hora);
    }),
  esHoy: f === hoy,
}));
---

<Layout>
  {todasFechas.length > 0 && (
    <PartidosDelDia
      todasFechas={todasFechas}
      dueñoEquipo={dueñoEquipo}
      equiposInfo={equiposInfo}
      inicioIndex={inicioIndex}
    />
  )}

  <!-- Tab: Grupos -->
  <div id="tab-grupos" class="tab-panel active">
    <div class="grupos-grid">
      {gruposEntries.map(([letra, grupo]) => (
        <TablaGrupo
          letra={letra}
          equipos={grupo.equipos}
          partidos={grupo.partidos}
          participantes={participantes}
        />
      ))}
    </div>
  </div>

  <!-- Tab: Eliminatorias -->
  <div id="tab-eliminatorias" class="tab-panel">
    <BracketEliminatorias
      treintaDos={eliminatorias.treintaDos}
      dieciseis={eliminatorias.dieciseis}
      cuartos={eliminatorias.cuartos}
      semis={eliminatorias.semis}
      tercerLugar={eliminatorias.tercerLugar}
      final={eliminatorias.final}
      participantes={participantes}
      equiposInfo={equiposInfo}
    />
  </div>

  <!-- Tab: Quiniela -->
  <div id="tab-quiniela" class="tab-panel">
    <TablaQuiniela
      participantes={participantes}
      equiposInfo={equiposInfo}
      campeon={campeon}
      eliminados={eliminados}
    />
  </div>
</Layout>

<style>
  .grupos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }
</style>
