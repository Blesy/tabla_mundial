---
interface Participante {
  nombre: string;
  equipos: string[];
}

interface Props {
  participantes: Participante[];
  equiposInfo: Record<string, { nombre: string; bandera: string }>;
  campeon: string | null;
  eliminados: Set<string>;
}

const { participantes, equiposInfo, campeon, eliminados } = Astro.props;

function estadoEquipo(id: string): 'campeon' | 'activo' | 'eliminado' {
  if (campeon === id) return 'campeon';
  if (eliminados.has(id)) return 'eliminado';
  return 'activo';
}

const conEstados = participantes.map(p => {
  const equipos = p.equipos.map(id => ({
    id,
    info: equiposInfo[id] ?? { nombre: id, bandera: '' },
    estado: estadoEquipo(id),
  }));
  const activos = equipos.filter(e => e.estado !== 'eliminado').length;
  const tieneCampeon = equipos.some(e => e.estado === 'campeon');
  return { ...p, equipos, activos, tieneCampeon };
});

const clasificados = [...conEstados].sort((a, b) => {
  if (b.tieneCampeon !== a.tieneCampeon) return b.tieneCampeon ? 1 : -1;
  return b.activos - a.activos;
});

const hayGanador = clasificados.some(p => p.tieneCampeon);
---

<div class="quiniela-wrapper">

  {hayGanador && (
    <div class="ganador-banner">
      🏆 ¡{clasificados.find(p => p.tieneCampeon)?.nombre} gana la quiniela!
    </div>
  )}

  <div class="resumen">
    <span>12 participantes · {campeon ? `Campeón: ${equiposInfo[campeon]?.nombre ?? campeon}` : 'Campeón por definirse'}</span>
  </div>

  <div class="tabla-quiniela">
    <div class="tabla-header">
      <span class="col-pos">#</span>
      <span class="col-nombre">Participante</span>
      <span class="col-equipos">Equipos</span>
      <span class="col-activos">Vivos</span>
    </div>

    {clasificados.map((p, i) => (
      <div class:list={['tabla-row', p.tieneCampeon ? 'row-campeon' : (i < 3 ? 'row-top' : '')]}>
        <span class="col-pos">
          {p.tieneCampeon ? '🏆' : i + 1}
        </span>
        <span class="col-nombre">
          {p.nombre}
          {p.tieneCampeon && <span class="ganador-tag">GANADOR</span>}
        </span>
        <span class="col-equipos">
          {p.equipos.map(eq => (
            <span class:list={['equipo-chip', `chip-${eq.estado}`]} title={eq.info.nombre}>
              <span class="chip-flag">{eq.info.bandera}</span>
              <span class="chip-name">{eq.info.nombre}</span>
            </span>
          ))}
        </span>
        <span class:list={['col-activos', p.activos === 0 ? 'cero' : '']}>
          {p.activos}/4
        </span>
      </div>
    ))}
  </div>

  <div class="leyenda">
    <span class="chip-activo-ex">🟢 Activo</span>
    <span class="chip-elim-ex">🔴 Eliminado</span>
    <span class="chip-camp-ex">🏆 Campeón</span>
  </div>
</div>

<style>
  .quiniela-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ganador-banner {
    background: linear-gradient(135deg, rgba(245, 197, 24, 0.2), rgba(245, 197, 24, 0.05));
    border: 2px solid var(--color-gold);
    border-radius: 10px;
    padding: 1rem 1.5rem;
    text-align: center;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-gold);
    letter-spacing: 0.03em;
  }

  .resumen {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .tabla-quiniela {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .tabla-header {
    display: grid;
    grid-template-columns: 2.5rem 1fr 1fr 3.5rem;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: var(--color-surface2);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--color-border);
  }

  .tabla-row {
    display: grid;
    grid-template-columns: 2.5rem 1fr 1fr 3.5rem;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--color-border);
    align-items: center;
    transition: background 0.1s;
  }

  .tabla-row:hover { background: var(--color-surface2); }

  .tabla-row.row-campeon {
    background: rgba(245, 197, 24, 0.06);
    border-left: 3px solid var(--color-gold);
  }

  .col-pos {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-align: center;
  }

  .col-nombre {
    font-weight: 600;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .ganador-tag {
    font-size: 0.6rem;
    font-weight: 700;
    background: var(--color-gold);
    color: #000;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    letter-spacing: 0.05em;
  }

  .col-equipos {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .equipo-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.2rem 0.45rem;
    border-radius: 5px;
    font-size: 0.72rem;
    font-weight: 600;
    border: 1px solid transparent;
  }

  .chip-activo {
    background: rgba(34, 197, 94, 0.12);
    border-color: rgba(34, 197, 94, 0.4);
    color: var(--color-green);
  }

  .chip-eliminado {
    background: rgba(239, 68, 68, 0.08);
    border-color: rgba(239, 68, 68, 0.2);
    color: var(--color-text-muted);
    text-decoration: line-through;
    opacity: 0.6;
  }

  .chip-campeon {
    background: rgba(245, 197, 24, 0.15);
    border-color: var(--color-gold);
    color: var(--color-gold);
    font-weight: 800;
  }

  .chip-flag { font-size: 1rem; }
  .chip-name { white-space: nowrap; }

  .col-activos {
    text-align: center;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-green);
  }

  .col-activos.cero { color: var(--color-red); }

  .leyenda {
    display: flex;
    gap: 1.25rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .tabla-header,
    .tabla-row {
      grid-template-columns: 2rem 1fr 3rem;
    }

    .col-equipos { display: none; }
  }
</style>
