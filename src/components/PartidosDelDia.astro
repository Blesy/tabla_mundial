---
interface PartidoConContexto {
  local: string | null;
  visitante: string | null;
  golesLocal: number | null;
  golesVisitante: number | null;
  contexto: string;
}

interface Props {
  partidos: PartidoConContexto[];
  fecha: string;
  esHoy: boolean;
  equiposInfo: Record<string, { nombre: string; bandera: string }>;
}

const { partidos, fecha, esHoy, equiposInfo } = Astro.props;

function formatFecha(f: string): string {
  const [year, month, day] = f.split('-').map(Number);
  const date = new Date(year, month - 1, day);
  return date.toLocaleDateString('es-MX', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function getEquipo(id: string | null) {
  if (!id) return { nombre: '?', bandera: '❓' };
  return equiposInfo[id] ?? { nombre: id, bandera: '🏴' };
}

function marcador(p: PartidoConContexto): string {
  if (p.golesLocal !== null && p.golesVisitante !== null) {
    return `${p.golesLocal} – ${p.golesVisitante}`;
  }
  return 'vs';
}
---

<section class="partidos-dia">
  <div class="partidos-dia-header">
    <div class="header-left">
      <span class="icono">📅</span>
      <div>
        <p class="header-titulo">{esHoy ? 'Partidos de Hoy' : 'Próximos Partidos'}</p>
        <p class="header-fecha">{formatFecha(fecha)}</p>
      </div>
    </div>
    {esHoy && <span class="badge-hoy">HOY</span>}
  </div>

  <div class="partidos-grid">
    {partidos.map((p) => {
      const local = getEquipo(p.local);
      const visitante = getEquipo(p.visitante);
      const jugado = p.golesLocal !== null && p.golesVisitante !== null;
      return (
        <div class={`partido-card ${jugado ? 'jugado' : 'pendiente'}`}>
          <span class="contexto-label">{p.contexto}</span>
          <div class="partido-row">
            <div class="equipo local-team">
              <span class="bandera">{local.bandera}</span>
              <span class="nombre">{local.nombre}</span>
            </div>
            <div class={`marcador ${jugado ? 'marcador-jugado' : ''}`}>
              {marcador(p)}
            </div>
            <div class="equipo visitante-team">
              <span class="nombre">{visitante.nombre}</span>
              <span class="bandera">{visitante.bandera}</span>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .partidos-dia {
    background: linear-gradient(135deg, #13131a 0%, #1a1a26 100%);
    border: 1px solid var(--color-accent);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 0 24px rgba(245, 197, 24, 0.08);
  }

  .partidos-dia-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 0.75rem;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .icono {
    font-size: 1.5rem;
    line-height: 1;
  }

  .header-titulo {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .header-fecha {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-transform: capitalize;
    margin-top: 0.1rem;
  }

  .badge-hoy {
    background: var(--color-accent);
    color: #000;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.55rem;
    border-radius: 20px;
    flex-shrink: 0;
  }

  .partidos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  .partido-card {
    background: var(--color-surface2);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    transition: border-color 0.15s;
  }

  .partido-card.jugado {
    border-left: 3px solid var(--color-green);
  }

  .partido-card.pendiente {
    border-left: 3px solid var(--color-accent);
  }

  .partido-card:hover {
    border-color: var(--color-accent);
  }

  .contexto-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  .partido-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.5rem;
  }

  .equipo {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    min-width: 0;
  }

  .local-team {
    justify-content: flex-end;
    text-align: right;
  }

  .visitante-team {
    justify-content: flex-start;
    text-align: left;
  }

  .bandera {
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .nombre {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .marcador {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-align: center;
    white-space: nowrap;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    min-width: 52px;
  }

  .marcador.marcador-jugado {
    color: var(--color-green);
    border-color: var(--color-green);
  }

  @media (max-width: 640px) {
    .partidos-grid {
      grid-template-columns: 1fr;
    }

    .nombre {
      font-size: 0.75rem;
    }
  }
</style>
