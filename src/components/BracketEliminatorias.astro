---
interface PartidoSimple {
  id: string;
  descLocal: string;
  descVisitante: string;
  local: string | null;
  visitante: string | null;
  golesLocal: number | null;
  golesVisitante: number | null;
  penalesLocal: number | null;
  penalesVisitante: number | null;
}

interface Props {
  treintaDos: PartidoSimple[];
  dieciseis: PartidoSimple[];
  cuartos: PartidoSimple[];
  semis: PartidoSimple[];
  tercerLugar: PartidoSimple;
  final: PartidoSimple;
  participantes: { nombre: string; equipos: string[] }[];
  equiposInfo: Record<string, { nombre: string; bandera: string }>;
}

const {
  treintaDos, dieciseis, cuartos, semis,
  tercerLugar, final: partidoFinal,
  participantes, equiposInfo,
} = Astro.props;

function getApostador(id: string | null): string {
  if (!id) return '';
  return participantes.find(p => p.equipos.includes(id))?.nombre ?? '';
}

// ── Build viewer participants ──────────────────────────────────────
const participantIds: Record<string, number> = {};
const viewerParticipants: { id: number; tournament_id: number; name: string }[] = [];
let pId = 0;

for (const [teamId, info] of Object.entries(equiposInfo)) {
  const ap = getApostador(teamId);
  participantIds[teamId] = pId;
  viewerParticipants.push({
    id: pId,
    tournament_id: 0,
    name: ap ? `${info.bandera} ${info.nombre} · ${ap}` : `${info.bandera} ${info.nombre}`,
  });
  pId++;
}

// Placeholder participants for R32 slots not yet assigned
const descToId: Record<string, number> = {};
for (const p of treintaDos) {
  for (const [teamId, desc] of [[p.local, p.descLocal], [p.visitante, p.descVisitante]] as [string | null, string][]) {
    if (!teamId && desc && !(desc in descToId)) {
      descToId[desc] = pId;
      viewerParticipants.push({ id: pId, tournament_id: 0, name: desc });
      pId++;
    }
  }
}

function getOpId(teamId: string | null, desc: string): number | null {
  if (teamId !== null) return participantIds[teamId] ?? null;
  return descToId[desc] ?? null;
}

// ── Build viewer matches ───────────────────────────────────────────
let matchId = 0;
function toMatch(roundId: number, groupId: number, num: number, p: PartidoSimple) {
  const op1id = getOpId(p.local, p.descLocal);
  const op2id = getOpId(p.visitante, p.descVisitante);

  let status: number;
  let r1: 'win' | 'loss' | undefined;
  let r2: 'win' | 'loss' | undefined;

  if (p.golesLocal !== null && p.golesVisitante !== null) {
    status = 4;
    const gl = p.golesLocal, gv = p.golesVisitante;
    if (gl > gv)        { r1 = 'win';  r2 = 'loss'; }
    else if (gl < gv)   { r1 = 'loss'; r2 = 'win';  }
    else if (p.penalesLocal !== null && p.penalesVisitante !== null) {
      r1 = p.penalesLocal > p.penalesVisitante ? 'win' : 'loss';
      r2 = p.penalesLocal > p.penalesVisitante ? 'loss' : 'win';
    }
  } else if (op1id !== null && op2id !== null) {
    status = 2;
  } else if (op1id !== null || op2id !== null) {
    status = 1;
  } else {
    status = 0;
  }

  const opp1: Record<string, unknown> = { id: op1id };
  const opp2: Record<string, unknown> = { id: op2id };
  if (p.golesLocal    !== null) opp1.score = p.golesLocal;
  if (p.golesVisitante !== null) opp2.score = p.golesVisitante;
  if (r1) opp1.result = r1;
  if (r2) opp2.result = r2;

  return { id: matchId++, stage_id: 0, group_id: groupId, round_id: roundId, number: num, child_count: 0, status, opponent1: opp1, opponent2: opp2 };
}

// round_id: 0=R32, 1=R16, 2=QF, 3=SF, 4=Final | group 1 → consolation
const viewerMatches = [
  ...treintaDos.map((p, i) => toMatch(0, 0, i + 1, p)),
  ...dieciseis .map((p, i) => toMatch(1, 0, i + 1, p)),
  ...cuartos   .map((p, i) => toMatch(2, 0, i + 1, p)),
  ...semis     .map((p, i) => toMatch(3, 0, i + 1, p)),
  toMatch(4, 0, 1, partidoFinal),
  toMatch(5, 1, 1, tercerLugar),
];

const viewerStages = [{
  id: 0, tournament_id: 0, name: 'Eliminatorias', type: 'single_elimination', number: 1,
  settings: { size: 32, consolationFinal: false, matchesChildCount: 0 },
}];

const bracketJSON = JSON.stringify({ stages: viewerStages, matches: viewerMatches, participants: viewerParticipants });

---


<div id="bracket-wrap">
  <div id="bracket" class="brackets-viewer"></div>
</div>

<script is:inline define:vars={{ bracketJSON }}>
  async function initBracket() {
    const data = JSON.parse(bracketJSON);

    if (!document.getElementById('bv-css')) {
      const link = document.createElement('link');
      link.id = 'bv-css';
      link.rel = 'stylesheet';
      link.href = 'https://cdn.jsdelivr.net/npm/brackets-viewer@latest/dist/brackets-viewer.min.css';
      document.head.appendChild(link);
    }

    if (!window.bracketsViewer) {
      await new Promise(function(resolve, reject) {
        const s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/brackets-viewer@latest/dist/brackets-viewer.min.js';
        s.onload = resolve;
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    await window.bracketsViewer.render(
      { stages: data.stages, matches: data.matches, matchGames: [], participants: data.participants },
      { 
        selector: '#bracket', 
        participantOriginPlacement: 'none', 
        showSlotsOrigin: false, 
        highlightParticipantOnHover: true, 
        clear: true ,
        customRoundName: function(round) {
          // 3rd-place match comes through with finalType = 'consolation-final'
          if (round.finalType === 'consolation-final') return '3er y 4to Lugar';
          // Main bracket: fractionOfFinal = 1/2^(roundCount - roundNumber)
          var inv = Math.round(1 / round.fractionOfFinal);
          if (inv === 16) return 'Dieciseisavos';
          if (inv === 8)  return 'Octavos';
          if (inv === 4)  return 'Cuartos';
          if (inv === 2)  return 'Semifinales';
          if (inv === 1)  return 'Final';
          return null; // fallback to default
        }
      }
    );
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBracket);
  } else {
    initBracket();
  }
</script>

<style>
  #bracket-wrap {
    overflow-x: auto;
    padding: 0.5rem 0 1.5rem;
  }

  /* Dark theme overrides for brackets-viewer */
  #bracket.brackets-viewer {
    --primary-background: #13131a;
    --secondary-background: #1c1c26;
    --match-background: #13131a;
    --font-color: #e8e8f0;
    --win-color: #22c55e;
    --loss-color: #ef4444;
    --label-color: #7070a0;
    --hint-color: #7070a0;
    --connector-color: #2a2a3a;
    --border-color: #2a2a3a;
    --border-hover-color: #3a3a52;
    --border-selected-color: #f5c518;
    --match-width: 220px;
    --round-margin: 32px;
    --text-size: 12px;
    background: transparent;
  }
</style>
